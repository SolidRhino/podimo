<body>
  <h1>Podimo-to-RSS converter</h1>
  <p>This program converts shows on Podimo to an RSS feed that can be used with any normal podcast player.</p>

  <details>
    <summary>Using Apple/Facebook/Google to log in to Podimo?</summary>
    <ol>
      <u>Try the following steps:</u>
      <li>Login at Podimo like you normally would</li>
      <li>Find the email address associated with your account. For Apple, this looks something like <em>abcdefg@privaterelay.appleid.com</em>. You should be able to find them somewhere on the settings page.</li>
      <li>Logout of Podimo.</li>
      <li>Instead of logging in to Podimo like normal, use the "Forgot password" form to reset your password. Put the email address from step 2 in here.</li>
      <li>Reset your password with the link from in your mailbox.</li>
      <li>You should now be able to login to Podimo with the email address from step 2 and the password you just created. You don't have to use the Sign in with Apple/Facebook/Google buttons anymore.</li>
      <li>Verify that you can login to Podimo with your new credentials. If you can, then <em>you are able to use this site!</em></li>
    </ol>
  </details>

  {{ if .Error }}
  <u><h2>Error: {{ .Error }}</h2></u>
  {{ end }}

  {{ if .NeedCredentials }}
  <div style="background:#f8d7da; color:#721c24; padding:1rem; margin-bottom:1rem;">
    <strong>⚠️ Warning:</strong> Your Podimo credentials will be embedded in the generated feed URL
    (e.g. <code>https://your-email:your-password@...</code>). This URL will be saved in your podcast app,
    browser history, and potentially server logs. Consider using <strong>LOCAL_CREDENTIALS=true</strong>
    for a single-user instance instead.
  </div>
  {{ end }}

  <form action="./" method="post">
    {{ if .NeedCredentials }}
    <label for="email">Your Podimo email address</label><br />
    <input type="email" required placeholder="Podimo email address" name="email" id="email"><br />

    <label for="password">Your Podimo password</label><br />
    <input type="password" required placeholder="Podimo password" name="password" id="password"><br />
    {{ end }}

    <h2>🔍 Search for podcast</h2>
    <label for="search_query">Search by name</label><br />
    <input type="text" placeholder="e.g. De Staat van Stasse" name="search_query" id="search_query" minlength="2">
    <button type="button" id="searchBtn">Search</button>
    <div id="searchResults" style="margin-top:0.5rem;"></div>

    <hr style="margin:1.5rem 0;" />

    <h2>📻 Or use your Podcast ID</h2>
    <label for="podcast_id">Podcast ID or URL</label><br />
    <small>Paste the full URL (e.g. <code>https://open.podimo.com/podcast/09c55c96-...</code>) or just the ID.</small><br />
    <input placeholder="Podcast ID or URL" required name="podcast_id" id="podcast_id" pattern="[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"><br />

    <label for="region">Region</label><br />
    <select name="region" id="region">
      {{ range .Regions }}
      <option value="{{ .Code }}">{{ .Name }}</option>
      {{ end }}
    </select>
    <br />

    <label for="locale">Locale</label><br />
    <select name="locale" id="locale">
      {{ range .Locales }}
      <option>{{ . }}</option>
      {{ end }}
    </select>

    <footer>
      Licensed under the EUPL-1.2 license - Source on <a href="https://github.com/izu-x/podimo">GitHub</a><br />
      If you find this useful, consider <a href="https://www.buymeacoffee.com/thijsr">buying the original author a coffee ☕</a>
    </footer>

    <input type="submit" value="Create RSS URL" />
  </form>

  <script>
    const input = document.getElementById('podcast_id');
    input.addEventListener('input', function () {
      const val = this.value.trim();
      const match = val.match(/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/i);
      if (match) {
        this.value = match[0];
      }
    });

    const searchBtn = document.getElementById('searchBtn');
    const searchInput = document.getElementById('search_query');
    const resultsDiv = document.getElementById('searchResults');

    async function doSearch() {
      const query = searchInput.value.trim();
      if (query.length < 2) return;

      resultsDiv.innerHTML = '<em>Searching...</em>';

      const url = new URL(window.location.origin + '/search');
      url.searchParams.set('q', query);

      {{ if .NeedCredentials }}
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      if (email && password) {
        url.username = encodeURIComponent(email);
        url.password = encodeURIComponent(password);
      }
      {{ end }}

      try {
        const response = await fetch(url.toString());
        if (!response.ok) {
          const text = await response.text();
          resultsDiv.innerHTML = '<span style="color:red">Error: ' + text + '</span>';
          return;
        }
        const data = await response.json();
        if (!data.results || data.results.length === 0) {
          resultsDiv.innerHTML = '<em>No podcasts found.</em>';
          return;
        }
        let html = '<ul style="list-style:none;padding:0;margin:0;">';
        for (const podcast of data.results) {
          html += '<li style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem;border-bottom:1px solid #eee;cursor:pointer;" onclick="selectPodcast(\'' + podcast.id + '\')">';
          if (podcast.coverImageUrl) {
            html += '<img src="' + podcast.coverImageUrl + '" width="48" height="48" style="border-radius:4px;object-fit:cover;">';
          }
          html += '<div><strong>' + podcast.title + '</strong>';
          if (podcast.authorName) html += '<br><small>' + podcast.authorName + '</small>';
          html += '</div></li>';
        }
        html += '</ul>';
        resultsDiv.innerHTML = html;
      } catch (err) {
        resultsDiv.innerHTML = '<span style="color:red">Search failed: ' + err.message + '</span>';
      }
    }

    searchBtn.addEventListener('click', doSearch);
    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        doSearch();
      }
    });

    window.selectPodcast = function(id) {
      document.getElementById('podcast_id').value = id;
      resultsDiv.innerHTML = '';
      searchInput.value = '';
    };
  </script>
</body>
</html>
